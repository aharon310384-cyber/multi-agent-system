# ============================================================
# OpenRouter — все LLM-вызовы идут через единый ключ
# Get key: https://openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-...

# Маршрутизация по типу задачи (опционально, есть дефолты в Backend/model-router.js)
# Доступные task-type override:
#   OPENROUTER_MODEL_DEFAULT       — fallback для всех (Designer, Sales, Account и т.п.)
#   OPENROUTER_MODEL_DEV           — Backend/Frontend/Mobile/QA/DevOps/AI-ML/Data/Security/TechLead
#   OPENROUTER_MODEL_MARKETING     — Стратег/Таргет/SEO/SMM/Аналитик/Копирайтер
#   OPENROUTER_MODEL_ORCHESTRATION — Главный оркестратор, PM, BA, ОСИНТ, decomposer/router/arbiter/memory
#   OPENROUTER_MODEL_IMAGE         — модель для /api/image (nano-banana)

# Дефолты:
# OPENROUTER_MODEL_DEFAULT=openai/gpt-5.5
# OPENROUTER_MODEL_DEV=anthropic/claude-opus-4.7
# OPENROUTER_MODEL_MARKETING=google/gemini-2.5-flash
# OPENROUTER_MODEL_ORCHESTRATION=minimax/minimax-m2
# OPENROUTER_MODEL_IMAGE=google/gemini-2.5-flash-image-preview

# Per-agent override (имеет приоритет над task-type):
# OPENROUTER_MODEL_BACKEND=anthropic/claude-opus-4.7
# OPENROUTER_MODEL_COPYWRITER=google/gemini-2.5-flash
# OPENROUTER_MODEL_DESIGNER=openai/gpt-5.5

# ============================================================
# Server
# ============================================================
# PORT=3000
